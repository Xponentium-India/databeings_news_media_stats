# ---- databeings backend config ----

# Postgres connection string (local, Supabase, Render, …)
DATABASE_URL=postgres://localhost:5432/databeings

# SSL: leave unset for auto (off for localhost, on for remote). Set explicitly when
# a host disagrees — e.g. self-hosted Supabase on a direct port often needs: false
DATABASE_SSL=

# Port the API listens on
PORT=4000

# Where the React app runs (for CORS + cookie). Dev = Vite:
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth 2.0 Web client ID (from Google Cloud Console).
# The SAME value must be set as VITE_GOOGLE_CLIENT_ID in the frontend .env.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Secret used to sign session cookies. Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Admin session cap in minutes (requirement: not more than 40)
SESSION_MINUTES=40

# Normal (non-admin) visitor session cap in minutes (requirement: 30)
VISITOR_SESSION_MINUTES=30

# OPEN LOGIN: leave empty so ANY Google account can sign in.
# Set to a workspace domain (e.g. xponentium.com) to restrict. Optional.
ALLOWED_EMAIL_DOMAIN=

# Local-only convenience: allow /api/auth/dev-login (skips Google) for testing.
# MUST be false/unset in production.
ALLOW_DEV_LOGIN=true

# Set to production when deployed (Secure + SameSite=None cookies, no dev-login).
NODE_ENV=development

# ---- image storage ----
# 'local' = save to server/uploads (dev / single VPS)
# 's3'    = upload to an S3-compatible bucket (AWS S3 or Cloudflare R2) in prod
STORAGE_DRIVER=local

# For local driver: set to your API origin to store absolute links (optional).
PUBLIC_BASE=

# Only needed when STORAGE_DRIVER=s3 ----------------------------------------
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_BUCKET=databeings-uploads
#   S3_ACCESS_KEY_ID=...
#   S3_SECRET_ACCESS_KEY=...
#   S3_PUBLIC_BASE=https://cdn.yourdomain.com   (public bucket / custom domain)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE=
