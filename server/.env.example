# ---- databeings backend config ----

# Postgres connection string
DATABASE_URL=postgres://localhost:5432/databeings

# Port the API listens on
PORT=4000

# Where the React app runs (for CORS + cookie). Dev = Vite:
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth 2.0 Web client ID (from Google Cloud Console).
# The SAME value must be set as VITE_GOOGLE_CLIENT_ID in the frontend .env.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Secret used to sign session cookies. Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Hard session cap in minutes (requirement: not more than 40)
SESSION_MINUTES=40

# Comma-separated emails allowed into /admin. The first time one of these
# logs in with Google they are granted is_admin = true.
ADMIN_EMAILS=you@example.com

# Local-only convenience: allow /api/auth/dev-login (skips Google) for testing.
# MUST be false/unset in production.
ALLOW_DEV_LOGIN=true

# Set to production when deployed (enables Secure cookies, disables dev-login).
NODE_ENV=development
