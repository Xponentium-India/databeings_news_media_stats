# ---- frontend (Vite) env ----
# Copy to .env.local and fill in.

# Google OAuth Web client ID (SAME value as GOOGLE_CLIENT_ID in server/.env).
# Leave blank to use the local "dev login" box instead during development.
VITE_GOOGLE_CLIENT_ID=

# Backend origin. Leave EMPTY in dev (Vite proxies /api and /uploads to :4000).
# In production set it to your deployed API, e.g. https://api.yourdomain.com
VITE_API_BASE=
